{
    "episode_event_summer_event_2026/4001_1001_100_10": "본격적으로 쏟아지기 시작했군...",
    "episode_event_summer_event_2026/4001_1001_200_10": "당장 오늘 밤에 태풍이\n상륙한다고 한다",
    "episode_event_summer_event_2026/4001_1001_300_10": "다들, 잘 들어라!\n그 누구도 거칠어진 바다에\n접근하지 못하게 하도록!",
    "episode_event_summer_event_2026/4002_1101_100_20": "다음 날 아침...",
    "episode_event_summer_event_2026/4002_1001_100_10": "이 주변에도 어젯밤에 온 태풍의\n영향이 남아 있네...",
    "episode_event_summer_event_2026/4002_1001_200_10": "피해를 입은 곳은...",
    "episode_event_summer_event_2026/4002_1001_300_10": "...응?",
    "episode_event_summer_event_2026/4002_1001_400_10": "포켓몬...일까?\n기운이 없어 보이는데...",
    "episode_event_summer_event_2026/4002_1001_500_10": "조금만 참아\n상처약을 써 줄게...!",
    "episode_event_summer_event_2026/4002_1001_600_10": "어때?\n조금은 괜찮아졌니?",
    "episode_event_summer_event_2026/4002_1001_700_10": "후훗, 다행이다!",
    "episode_event_summer_event_2026/6801_1031_100_10": "바다를 만끽해요!",
    "episode_event_summer_event_2026/6801_1001_100_10": "바다에서의 즐거움은\n헤엄치는 게 전부가 아니라고 해요",
    "episode_event_summer_event_2026/6801_1001_200_10": "뭐~?\n불꽃놀이라도 볼 수 있는 거야?",
    "episode_event_summer_event_2026/6801_1001_300_10": "바다의 집이라는 시설에서는\n맛있는 음식도 판다던데요?",
    "episode_event_summer_event_2026/6801_1001_400_10": "아하하! 그건 확실히\n커다란 즐거움이긴 하네!",
    "episode_event_summer_event_2026/4003_1101_100_20": "다음 날...",
    "episode_event_summer_event_2026/4003_1001_100_10": "그래서 네가 돌보게 되었다는 거구나?",
    "episode_event_summer_event_2026/4003_1001_200_10": "네, 아무래도\n제가 마음에 들었나 봐요...",
    "episode_event_summer_event_2026/4003_1001_300_10": "환상의 포켓몬의 마음에 들다니\n대단한데!",
    "episode_event_summer_event_2026/4003_1001_400_10": "그 포켓몬... 마나피에게는\n바다에 얽힌 전설이 전해지거든",
    "episode_event_summer_event_2026/4003_1001_500_10": "아주 이상한 힘을 지니고 있다던데...\n...뭐 그렇다나 봐!",
    "episode_event_summer_event_2026/4003_1001_600_10": "이상한 힘...이요?",
    "episode_event_summer_event_2026/4003_1001_700_10": "맞아! 어떤 포켓몬과도\n마음이 서로 통할 수 있다고 해!",
    "episode_event_summer_event_2026/4003_1001_800_10": "와아...!\n마나피는 정말 대단한 포켓몬이었군요?",
    "episode_event_summer_event_2026/4003_1001_900_10": "윤슬!",
    "episode_event_summer_event_2026/4003_1001_1000_10": "마나피는 좀 어때?",
    "episode_event_summer_event_2026/4003_1001_1100_10": "원래는 바다에 사는 포켓몬인 것 같은데\n육지 생활에도 조금씩 적응하고 있는 것 같아요",
    "episode_event_summer_event_2026/4003_1001_1200_10": "가능하면 빨리 바다에 넣어 주고 싶은데\n부상이 다 낫기 전에는...",
    "episode_event_summer_event_2026/4003_1001_1300_10": "맞아, 답답하긴 해도\n자제하는 게 좋을 거 같아",
    "episode_event_summer_event_2026/4003_1001_1400_10": "포켓몬이 바라는 대로\n해 줄 수 없다는 게 안타깝네...",
    "episode_event_summer_event_2026/4003_1001_1500_10": "원래는 바다에 사는 포켓몬이니 말이지...",
    "episode_event_summer_event_2026/4003_1001_1600_10": "하지만 윤슬의 곁에 있는 게\n편안한 것 같아!",
    "episode_event_summer_event_2026/4003_1001_1700_10": "나도 함께 있을 수 있어서 기뻐\n마나피!",
    "episode_event_summer_event_2026/4003_1001_1800_10": "이쪽 문제는 걱정 안 해도 될 거 같네",
    "episode_event_summer_event_2026/4003_1001_1900_10": "남은 건...",
    "episode_event_summer_event_2026/4003_1001_2000_10": "으아아!?\n그만 좀 하고 진정하라니까!",
    "episode_event_summer_event_2026/4003_1001_2100_10": "성화와 대쓰여너의 문제지...",
    "episode_event_summer_event_2026/4003_1001_2200_10": "성화씨! 괜찮으세요!?",
    "episode_event_summer_event_2026/4003_1001_2300_10": "앗, 다들 왔구나...!",
    "episode_event_summer_event_2026/4003_1001_2400_10": "아하하, 부끄러운 모습을 보여 버렸네",
    "episode_event_summer_event_2026/4003_1001_2500_10": "본 적 없는 포켓몬이네...!",
    "episode_event_summer_event_2026/4003_1001_2600_10": "배쓰나이를 조금 닮은 것 같은데...",
    "episode_event_summer_event_2026/4003_1001_2700_10": "미도씨 일행하고 \"시공의 뒤틀림\"을\n조사하러 갔을 때 만났어요",
    "episode_event_summer_event_2026/4003_1001_2800_10": "...정신없이 날뛰고 다니길래\n피해를 끼치지 못하게 잡았었는데",
    "episode_event_summer_event_2026/4003_1001_2900_10": "그 이후로는 전혀 말을 듣질 않아요...",
    "episode_event_summer_event_2026/4003_1001_3000_10": "파시오에 남겨진 게 마음에 안 드는 걸까?",
    "episode_event_summer_event_2026/4003_1001_3100_10": "그런 것도 있을지도 모르지만...",
    "episode_event_summer_event_2026/4003_1001_3200_10": "전에 학자 선생한테\n대쓰여너에 대해 들은 적이 있어",
    "episode_event_summer_event_2026/4003_1001_3300_10": "학자 선생이라면...\n히스이지방의 라벤박사님 말이죠?",
    "episode_event_summer_event_2026/4003_1001_3400_10": "맞아",
    "episode_event_summer_event_2026/4003_1001_3500_10": "뜻을 이루지 못하고 죽은 동료들의\n혼을 두르고 있는 포켓몬이라서\n분노에 마음을 지배당하고 있다고...",
    "episode_event_summer_event_2026/4003_1001_3600_10": "그때 듣기론 그렇댔어",
    "episode_event_summer_event_2026/4003_1001_3700_10": "...내 조로아크도\n뭔가 감지한 것 같아",
    "episode_event_summer_event_2026/4003_1001_3800_10": "대쓰여너의 분노는\n조로아크가 지닌 원념에 가까운 걸지도 몰라...",
    "episode_event_summer_event_2026/4003_1001_3900_10": "동료들의 한을\n짊어지고 있는 걸지도 모르겠네요",
    "episode_event_summer_event_2026/4003_1001_4000_10": "그거참 어려운 포켓몬이네...",
    "episode_event_summer_event_2026/4003_1001_4100_10": "마나피도 대쓰여너가 걱정돼?",
    "episode_event_summer_event_2026/4003_1001_4200_10": "저기... 성화씨\n그 대쓰여너 말인데요",
    "episode_event_summer_event_2026/4003_1001_4300_10": "마나피와 함께 파시오에서\n즐거운 추억을 만들어 주는 건 어떨까요?",
    "episode_event_summer_event_2026/4003_1001_4400_10": "뭐?",
    "episode_event_summer_event_2026/4003_1001_4500_10": "그렇게 하면 조금이라도\n분노가 가라앉을지도 모르잖아요!",
    "episode_event_summer_event_2026/4003_1001_4600_10": "그렇겠지...?",
    "episode_event_summer_event_2026/4003_1001_4700_10": "응! 해 볼래!\n고민만 하느니 뭐라도 시도해 봐야지!",
    "episode_event_summer_event_2026/4003_1001_4800_10": "하기로 정했으면 바로 실행으로 옮겨야지!\n빨리 시작하자고",
    "episode_event_summer_event_2026/4003_1001_4900_10": "이참에 옷도 포켓몬들하고\n맞춰서 입어 보는 건 어때?",
    "episode_event_summer_event_2026/4003_1001_5000_10": "우리도 그렇게 해서\n조로아크나 다투곰과 마음이 통했거든!",
    "episode_event_summer_event_2026/4003_1001_5100_10": "의상을 맞춰 입는 것도\n좋은 아이디어 같아!",
    "episode_event_summer_event_2026/4003_1001_5200_10": "그러게요!\n바로 고르러 가 봐요",
    "episode_event_summer_event_2026/4004_1001_100_10": "이 복장이 딱 좋을 것 같아!",
    "episode_event_summer_event_2026/4004_1001_200_10": "응! 두 사람 모두\n정말 잘 어울려!",
    "episode_event_summer_event_2026/4004_1001_300_10": "마나피는 어때?",
    "episode_event_summer_event_2026/4004_1001_400_10": "하하하!\n마음에 들었나 봐!",
    "episode_event_summer_event_2026/4004_1001_500_10": "대쓰여너는...",
    "episode_event_summer_event_2026/4004_1001_600_10": "자, 잠깐만...!\n어디 가는 거야!?",
    "episode_event_summer_event_2026/4004_1001_700_10": "이건 생각보다\n시간이 더 필요하겠는걸...",
    "episode_event_summer_event_2026/4004_1001_800_10": "역시 육지에 있으면 불편해?",
    "episode_event_summer_event_2026/4004_1001_900_10": "상처도 곧 다 나을 테니까\n조금만 더 참아 줘",
    "episode_event_summer_event_2026/4004_1001_1000_10": "마나피...\n처음에는 바로 바다에\n들어가고 싶어했었지?",
    "episode_event_summer_event_2026/4004_1001_1100_10": "네, 육지가 익숙하지 않아서\n당혹스러워하는 것 같았어요",
    "episode_event_summer_event_2026/4004_1001_1200_10": "...그렇게 두려워하는 마음은\n자신을 지키기 위해서 필요한 거겠죠",
    "episode_event_summer_event_2026/4004_1001_1300_10": "하지만 용기를 내서 한 걸음 나아갔을 때\n넓어지는 세계도 있어요",
    "episode_event_summer_event_2026/4004_1001_1400_10": "제가 경험한 것처럼\n마나피도 즐거운 세계가 있다는 것을\n느껴 줬으면 해요...",
    "episode_event_summer_event_2026/4004_1001_1500_10": "그 마음이 조금이라도\n전해진다면 좋겠지만...",
    "episode_event_summer_event_2026/4004_1001_1600_10": "분명 마나피에게도\n전해졌을 거야!",
    "episode_event_summer_event_2026/4004_1001_1700_10": "그도 그럴 게, 육지에 온 덕분에\n윤슬하고 만날 수 있었잖아!",
    "episode_event_summer_event_2026/4004_1001_1800_10": "...그렇겠죠!",
    "episode_event_summer_event_2026/4004_1001_1900_10": "내가 곁에 있어 줄 테니까\n힘내, 마나피!",
    "episode_event_summer_event_2026/4004_1001_2000_10": "...얼마나 날뛰든 간에\n난 포기할 생각 없어",
    "episode_event_summer_event_2026/4004_1001_2100_10": "대쓰여너...\n네 마음이 나랑 파시오를\n받아들일 그때까지 말이야!",
    "episode_event_summer_event_2026/4004_1001_2200_10": "이렇게 된 이상 끈기 대결이로군...",
    "episode_event_summer_event_2026/4004_1001_2300_10": "너, 조금 집착하고 있는 거 아냐?",
    "episode_event_summer_event_2026/4004_1001_2400_10": "네가 그렇게까지 애쓰는 이유는 뭐야?",
    "episode_event_summer_event_2026/4004_1001_2500_10": "...성화, 너는 과거의 실패를\n반복하고 싶지 않은 거지?",
    "episode_event_summer_event_2026/4004_1001_2600_10": "실패?",
    "episode_event_summer_event_2026/4004_1001_2700_10": "...네, 히스이지방에 있을 때의 일이에요",
    "episode_event_summer_event_2026/4004_1001_2800_10": "저 혼자서 문제를 해결하려고 하다가\n모두에게 폐를 끼쳤었거든요",
    "episode_event_summer_event_2026/4004_1001_2900_10": "그때는 초조해져서 올바른 방법으로\n포켓몬에게 다가가지 못했어요...",
    "episode_event_summer_event_2026/4004_1001_3000_10": "그러니까 이번에는 제대로...!",
    "episode_event_summer_event_2026/4004_1001_3100_10": "그런 거였구나...",
    "episode_event_summer_event_2026/4004_1001_3200_10": "그렇다면 그 반성점을\n잘 개선한 셈이네",
    "episode_event_summer_event_2026/4004_1001_3300_10": "네?",
    "episode_event_summer_event_2026/4004_1001_3400_10": "이번에는 제대로 동료를\n의지하고 있잖아!",
    "episode_event_summer_event_2026/4004_1001_3500_10": "그래!\n이번에야말로 리더인\n나를 믿으라고, 성화!",
    "episode_event_summer_event_2026/4004_1001_3600_10": "나도 너희 둘의 거리가\n가까워질 수 있게 응원할게!",
    "episode_event_summer_event_2026/4004_1001_3700_10": "네...!\n모두 고마워요!",
    "episode_event_summer_event_2026/4004_1001_3800_10": "...대쓰여너, 너는\n잃어버린 동료들의 분노를\n짊어지고 날뛰고 있는 거지?",
    "episode_event_summer_event_2026/4004_1001_3900_10": "그건 괴롭기도 하고 슬프기도 할 거 같아...\n잃어버린 동료들을 돌려줄 방법은 없지만...",
    "episode_event_summer_event_2026/4004_1001_4000_10": "내가 새로운 동료가 되어 줄게!",
    "episode_event_summer_event_2026/4004_1001_4100_10": "성화씨와 대쓰여너...\n잘 풀렸으면 좋겠네요",
    "episode_event_summer_event_2026/4004_1001_4200_10": "저도 마나피의 상처를 치료해서\n바다로 돌려보낼 수 있게 힘내야겠어요!",
    "episode_event_summer_event_2026/4004_1001_4300_10": "있잖아, 윤슬\n역시 마나피하고는...",
    "episode_event_summer_event_2026/4004_1001_4400_10": "대쓰여너... 대체 왜 그러는 거야...!",
    "episode_event_summer_event_2026/4004_1001_4500_10": "네 분노는...\n정말로 가라앉힐 수 없는 거야!?",
    "episode_event_summer_event_2026/4005_1001_100_10": "이제 그만해!",
    "episode_event_summer_event_2026/4005_1001_200_10": "분노에 몸을 맡기고 날뛰어 봐야\n너 스스로를 다치게 할 뿐이잖아!",
    "episode_event_summer_event_2026/4005_1001_300_10": "네가 괴로워하는 모습을\n더는 못 보겠단 말이야...!",
    "episode_event_summer_event_2026/4005_1001_400_10": "순순히 말을 들을 마음은 없나 보네",
    "episode_event_summer_event_2026/4005_1001_500_10": "성화가 이렇게까지\n필사적으로 마음을 전하고 있는데도...",
    "episode_event_summer_event_2026/4005_1001_600_10": "...알았어, 대쓰여너\n말로 해도 못 알아듣겠다면",
    "episode_event_summer_event_2026/4005_1001_700_10": "내 마음을 직접 부딪혀 줄게!",
    "episode_event_summer_event_2026/4005_1001_800_10": "가자, 드레디어!\n나한테 힘을 빌려줘!",
    "episode_event_summer_event_2026/4005_1001_900_10": "제발 깨달아 줘...!",
    "episode_event_summer_event_2026/4005_1001_1000_10": "우리도 너와 싸우고 싶지는 않아...!",
    "episode_event_summer_event_2026/4005_1001_1100_10": "제아무리 열심히 마음을 쏟아도\n그게 꼭 통하지는 않는 법인가...",
    "episode_event_summer_event_2026/4005_1001_1200_10": "마음이... 통하게...",
    "episode_event_summer_event_2026/4005_1001_1300_10": "...이제 그만해! 성화!",
    "episode_event_summer_event_2026/4005_1001_1400_10": "이렇게 계속하면 분노를 받아내는\n네가 못 견디게 될 거야!",
    "episode_event_summer_event_2026/4005_1001_1500_10": "우리도 도와줄게!",
    "episode_event_summer_event_2026/4005_1001_1600_10": "잠깐만요!",
    "episode_event_summer_event_2026/4005_1001_1700_10": "이번에는 마나피의 힘을 빌려 봐요!",
    "episode_event_summer_event_2026/4005_1001_1800_10": "그게 무슨...?",
    "episode_event_summer_event_2026/4005_1001_1900_10": "설명은 이따가 할게요!\n마나피, 부탁해!",
    "episode_event_summer_event_2026/4005_1001_2000_10": "성화씨, 지금이에요!",
    "episode_event_summer_event_2026/4005_1001_2100_10": "뭘 해 준 건지는 모르겠지만...\n고마워!",
    "episode_event_summer_event_2026/4005_1001_2200_10": "대쓰여너!\n부탁이야! 제발 진정해!!",
    "episode_event_summer_event_2026/4005_1001_2300_10": "가라앉힌 건가...!?",
    "episode_event_summer_event_2026/4005_1001_2400_10": "아니... 방금은 어떻게 한 거야?",
    "episode_event_summer_event_2026/4005_1001_2500_10": "마나피는 어떤 포켓몬과도\n마음이 서로 통하게 되는...\n그런 힘이 있다고 해요",
    "episode_event_summer_event_2026/4005_1001_2600_10": "그러니 마나피의 힘을 빌리면\n성화씨의 마음도\n분명 전해질 거라는 생각이 들었어요!",
    "episode_event_summer_event_2026/4005_1001_2700_10": "설마 바다의 전설을\n내가 직접 보게 될 줄이야...!",
    "episode_event_summer_event_2026/4005_1001_2800_10": "대쓰여너\n이제는 날뛰지 않을 거지...?",
    "episode_event_summer_event_2026/4005_1001_2900_10": "걱정 마, 네가 필사적으로\n마주보려 했던 노력이 결실을 맺은 거니까",
    "episode_event_summer_event_2026/4005_1001_3000_10": "분노에 지배당한 상태였어도\n성화의 목소리는\n제대로 전해지고 있었던 거야!",
    "episode_event_summer_event_2026/4005_1001_3100_10": "새로운 버디즈의 탄생이네!",
    "episode_event_summer_event_2026/4005_1001_3200_10": "그렇구나...\n다시 한번 잘 부탁해, 대쓰여너!",
    "episode_event_summer_event_2026/4005_1001_3300_10": "앞으로는 계속 나랑 함께야!\n더는 외롭게 하지 않을게!",
    "episode_event_summer_event_2026/4005_1001_3400_10": "잘됐네요, 성화씨!\n축하드려요!",
    "episode_event_summer_event_2026/4005_1001_3500_10": "... ... ...",
    "episode_event_summer_event_2026/4006_1001_100_10": "마나피의 부상도\n이제 괜찮아졌으니",
    "episode_event_summer_event_2026/4006_1001_200_10": "슬슬 바다로 돌려보내도\n건강하게 헤엄칠 수 있을 거 같네요",
    "episode_event_summer_event_2026/4006_1001_300_10": "윤슬...\n처음부터 그렇게 말하던데",
    "episode_event_summer_event_2026/4006_1001_400_10": "정말 이대로 헤어질 거야?",
    "episode_event_summer_event_2026/4006_1001_500_10": "마나피는 바다로 돌아가고 싶어했으니...\n억지로 붙들면 불쌍하잖아요",
    "episode_event_summer_event_2026/4006_1001_600_10": "... ... ...",
    "episode_event_summer_event_2026/4006_1001_700_10": "계속 다짐하고 있었어요",
    "episode_event_summer_event_2026/4006_1001_800_10": "내 쪽에서 버디즈가 되자고\n말을 꺼내지는 않겠다고...",
    "episode_event_summer_event_2026/4007_1001_100_10": "윤슬도 마나피도\n함께 있어서 즐거웠잖아!",
    "episode_event_summer_event_2026/4007_1001_200_10": "그러니 앞으로도...",
    "episode_event_summer_event_2026/4007_1001_300_10": "...버디즈가 될 수 없는 데에는\n이유가 하나 더 있어요",
    "episode_event_summer_event_2026/4007_1001_400_10": "마나피는 이 시대의 포켓몬이고...\n저는 히스이 시대의 사람이잖아요",
    "episode_event_summer_event_2026/4007_1001_500_10": "아...",
    "episode_event_summer_event_2026/4007_1001_600_10": "... ... ...",
    "episode_event_summer_event_2026/4007_1001_700_10": "저, 마나피를 보고 있으면\n영빈이 계속 겹쳐 보이더라고요",
    "episode_event_summer_event_2026/4007_1001_800_10": "영빈도 원래는 다른 장소에서\n히스이지방에 오게 된 사람이죠",
    "episode_event_summer_event_2026/4007_1001_900_10": "언젠가 기억을 되찾아서\n\"있어야 할 장소\"로 돌아가기로 한다면\n그때는...",
    "episode_event_summer_event_2026/4007_1001_1000_10": "웃으면서 배웅해 주기로\n그렇게 마음먹었어요",
    "episode_event_summer_event_2026/4007_1001_1100_10": "그래서 윤슬은 마나피하고도\n계속 같이 있을 수는 없다고 생각하는 거야...?",
    "episode_event_summer_event_2026/4007_1001_1200_10": "네",
    "episode_event_summer_event_2026/4007_1001_1300_10": "성화씨와 대쓰여너처럼\n같이 있어야만 할 사정이 있으면\n그때는 또 모르겠지만요",
    "episode_event_summer_event_2026/4007_1001_1400_10": "...영빈도",
    "episode_event_summer_event_2026/4007_1001_1500_10": "기억이 돌아오더라도 은하단에\n남기로 선택해 준다면 좋겠네요...",
    "episode_event_summer_event_2026/4007_1001_1600_10": "... ... ...",
    "episode_event_summer_event_2026/4007_1001_1700_10": "...하지만 이런 억지를 부려서\n곤란하게 만들면 안 되겠죠!",
    "episode_event_summer_event_2026/4007_1001_1800_10": "그러니까 영빈한테도 마나피한테도\n계속 함께 있어 달라는 말은 못 하겠어요",
    "episode_event_summer_event_2026/4007_1001_1900_10": "...나는 윤슬의 생각을 존중해",
    "episode_event_summer_event_2026/4007_1001_2000_10": "아무리 좋은 제안이라고 해도...\n가야 할 길이 정해져 버리는 게\n행복한 거라고는 할 수 없으니까 말이야",
    "episode_event_summer_event_2026/4007_1001_2100_10": "하지만 윤슬, 반대로 말하면\n어떤 길을 선택할지는 자기한테 달린 거야",
    "episode_event_summer_event_2026/4007_1001_2200_10": "맞아!\n어떤 결과가 나올지는 아직...",
    "episode_event_summer_event_2026/4007_1001_2300_10": "앗...",
    "episode_event_summer_event_2026/4007_1001_2400_10": "마나피가 바다로...",
    "episode_event_summer_event_2026/4007_1001_2500_10": "...역시",
    "episode_event_summer_event_2026/4007_1001_2600_10": "있어야 할 장소로 돌아가는 게\n가장 좋은 거겠죠?",
    "episode_event_summer_event_2026/4008_1101_100_20": "며칠 후...",
    "episode_event_summer_event_2026/4008_1001_100_10": "... ... ...",
    "episode_event_summer_event_2026/4008_1001_200_10": "마나피...! 어째서...!?",
    "episode_event_summer_event_2026/4008_1001_300_10": "축하드려요!\n윤슬 선배",
    "episode_event_summer_event_2026/4008_1001_400_10": "영빈!?",
    "episode_event_summer_event_2026/4008_1001_500_10": "저기...\n축하한다니 대체 뭘...?",
    "episode_event_summer_event_2026/4008_1001_600_10": "사실은 다른 사람들한테\n마나피에 대한 이야기를 들었어요",
    "episode_event_summer_event_2026/4008_1001_700_10": "원래는 괜히 참견하지 말고\n가만히 지켜볼 생각이었는데요...",
    "episode_event_summer_event_2026/4008_1001_800_10": "마나피가 윤슬 선배를\n찾는 것 같아 보여서요",
    "episode_event_summer_event_2026/4008_1001_900_10": "뭐...?",
    "episode_event_summer_event_2026/4008_1001_1000_10": "바다에는 잠깐 놀러 가고 싶었을 뿐이었나 봐",
    "episode_event_summer_event_2026/4008_1001_1100_10": "...마나피\n돌아와 준 거야?",
    "episode_event_summer_event_2026/4008_1001_1200_10": "저, 윤슬 선배하고 마나피는\n분명 버디즈가 될 거라고 확신했어요!",
    "episode_event_summer_event_2026/4008_1001_1300_10": "하지만 너랑 나는...",
    "episode_event_summer_event_2026/4008_1001_1400_10": "살아 온 장소와 시대가 달라도\n서로를 생각하는 마음은 같잖아요?",
    "episode_event_summer_event_2026/4008_1001_1500_10": "뭐?",
    "episode_event_summer_event_2026/4008_1001_1600_10": "종족이 달라도 상관없어요",
    "episode_event_summer_event_2026/4008_1001_1700_10": "특별한 힘도 필요 없고요",
    "episode_event_summer_event_2026/4008_1001_1800_10": "각자가 함께 있고 싶다고 바란다면...",
    "episode_event_summer_event_2026/4008_1001_1900_10": "마음은 반드시\n서로 통하게 될 테니까요!",
    "episode_event_summer_event_2026/4008_1001_2000_10": "영빈...",
    "episode_event_summer_event_2026/4008_1001_2100_10": "자! 저희 \"히스이 사람들\"에게\n새로운 동료가 늘어난 것을\n축하하도록 해요!",
    "episode_event_summer_event_2026/4008_1001_2200_10": "토란떡도 잔뜩 준비해 놨어!",
    "episode_event_summer_event_2026/4008_1001_2300_10": "빨리 와!\n주인공이 안 오면 시작을 못 한다고!",
    "episode_event_summer_event_2026/4008_1001_2400_10": "...네!",
    "episode_event_summer_event_2026/4008_1001_2500_10": "가자! 마나피!"
}
