{
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1101_0100_20": "ある日　[Name:PlayerNickname ]は\nショウから　呼びだされた",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_0200_10": "[Name:PlayerNickname ]\n来てくれて　ありがとうございます",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_0300_10": "話というのは　ですね……",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_0400_10": "いつも　よくしてくれる\nお礼をしたいと　思いまして",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_0500_10": "パシオに　来たばかりの頃は\nわからないことが　多くて\n不安でしたけど……",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_0600_10": "[Name:PlayerNickname ]は　そんな　あたしを\nいつも　気にかけてくれて\nその優しさが　心強かったんです",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_0700_10": "だから　あなたに\nなにか　お礼をしたい　と！",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_0800_10": "そこで　どうでしょう\nあたしが得意な　クラフトを教えるので\nなにか　作ってみませんか？",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_0900_10": "この時代では　いい物が　なんでも\nすぐ　手に入りますけど",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_1000_10": "だからこそ　手作り　ならではの\nよさも　あると　思うんです！",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_1100_10": "もっとも……\n手間は　かかりますし",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_1200_10": "お店で　買う以上の\n品質にするのは　難しいので\n必要ないかも　しれませんけど……",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_0301_1300_10": "そんなことないよ　という",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_0401_1400_10": "そう……　ですか？",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_0401_1500_10": "役に立つのなら　うれしいです！",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_0302_1600_10": "手作りが好きだと　伝える",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_0402_1700_10": "本当ですか？　うれしいです！",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_1800_10": "それでは　クラフト名人として\n手作りのコツを　教えますね",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_1900_10": "ひと通り　作業が　終わったら\nイモモチでも　食べられると\nいいんですけど……",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_2000_10": "ヒスイの　イモモチは\nケムリイモから　作る　料理で",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_2100_10": "コトブキムラでは　任務終わりに\nよく　食べていました",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_2200_10": "ヒスイで　慣れ親しんだ\nあの味を　パシオでも\n再現してみたい　ところです",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_2300_10": "あなたにも　味わって　もらいたいので\n今度　がんばって　作ってみますね！",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1101_0100_20": "後日……",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_0200_10": "[Name:PlayerNickname ]\nクラフトの　調子は　どうですか？",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_0300_10": "慣れるまで　時間が\nかかると　思いますが",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_0400_10": "経験が　ものを　いうので\nがんばって　ください！",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_0500_10": "じつは　あたしも　今日\nイモモチを　作ったんですよ！",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_0600_10": "前に　話したこと　覚えてますか？",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_0700_10": "ヒスイの味を　再現しようと\nさっそく　挑戦して　みたんです",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_0800_10": "ただ　残念ながら\nヒスイ地方に　あったような\nケムリイモが　手に入らなかったので",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_0900_10": "別の物で　代用して　なんとか\nそれらしくは　作れたのですけど\n正直　あまり　自信がなくて……",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_1000_10": "……や　やっぱり　今回は\n渡すの　やめておきます！",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_1100_10": "また今度　うまく作れたら\n持ってきますね！",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_0301_1200_10": "ぜひ　食べさせてほしいと　いう",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_0401_1300_10": "そ　そういって　くれるのでしたら……",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_0302_1400_10": "自信を持ってほしいと　伝える",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_0402_1500_10": "……そうですね\n自分で　作った物　なんですから！",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_0402_1600_10": "わかりました\nせっかくなので　どうぞ！",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_1700_10": "あ　でも　ちょっと　恥ずかしいので\nあとで　食べてもらっても　いいですか？",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_1800_10": "感想は　今度　会ったときに\n教えていただく　ということで……！",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_1900_10": "そしたら　次は　もっと　おいしく\n作れるように　がんばれますから！"
}
