{
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1101_0100_20": "어느 날 [Name:PlayerNickname ][Kor:Particle char=\"ha\" ]\n하행에게 부탁이 있다며\n호출을 받았다...",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_0200_10": "[Name:PlayerNickname ], 부탁이야\n나와 태그를 맺어 줘!",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_0300_10": "응? 왜 이런 부탁을 하는지가\n궁금하다고?",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_0400_10": "나는 이 섬의\n버디즈를 보고 깨달았어",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_0500_10": "전력을 다하는 진지한 대결이라는 게\n사람에 따라서 전혀 다르다는 사실을 말이지",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_0600_10": "이기고 싶은 강한 마음과\n진심을 맞부딪치는 것\n나한테는 그게 진지한 대결이야",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_0700_10": "하지만 특정한 타입이나 전법으로 겨루어야\n진지한 대결이 되는 거라고\n말하는 사람도 있고",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_0800_10": "이기고 지는 것에 연연하지 않고\n쇼와 같은 포켓몬 승부를 펼쳐서\n관객을 매료시키고 싶어 하는 사람도 있어",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_0900_10": "그래서 나는\n모두가 생각하는 진지한 대결이\n어떤 것인지 더 잘 알고 싶어!",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_1000_10": "진지한 대결이라는 것의 다양한 형태를 알게 되면\n분명 지금보다 더 즐거울 테니까",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_1100_10": "그리고 그때 마침 떠오른 거야\n[Name:PlayerNickname ]의 얼굴이 말이지!",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_1200_10": "너는 언제나 전력을 다하고\n모든 일에 진지하게 임하잖아",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_1300_10": "그러니 너와 태그를 맺으면\n많이 배울 수 있을 게 분명해!",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_1400_10": "너와 함께라면 확실하게\n새로운 발견을 할 수 있을 거야!",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_0301_1500_10": "상행이 아니어도 괜찮냐고 묻는다",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_0401_1600_10": "응, 이번에는\n너와 함께하고 싶어!",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_0302_1700_10": "상행과도 이야기가 된 일인지 묻는다",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_0402_1800_10": "상행한테는 아무 말도 안 했어\n하지만 괜찮아",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_1900_10": "상행도 보나 마나\n나랑 같은 생각을 하고 있을 테니까",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_2000_10": "서브웨이마스터로서\n더 높은 목적지를 향해 움직이고 있을 거야",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_2100_10": "떨어져 있어도 우리들의\n콤비네이션은 최고!",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_2200_10": "나아가는 선로는 달라도...\n종착역은 틀림없이 같을 거야!",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1101_0100_20": "다음 날...",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_0200_10": "내 부탁을 들어줘서\n고마워, [Name:PlayerNickname ]",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_0300_10": "너와의 태그배틀은\n매 순간이 아주 즐거웠어!",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_0400_10": "그리고 알게 된 것도 있어",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_0500_10": "너는 아무 일에나\n전부 진지한 게 아니었어",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_0600_10": "무언가를 마주하는 일일 때\n항상 진지한 거였지",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_0700_10": "그게 포켓몬이든 승부든...\n사람의 마음이든 말이야!",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_0800_10": "너는 상대를 이해하고\n다가가려는 마음이 강한 사람이야",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_0900_10": "그래서 나를 향해서도\n진지하게 마주 봐 준 거지",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_1000_10": "너와 함께하니\n아주 싸우기 편했고\n무엇보다도 즐거웠어!",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_0301_1100_10": "나도 즐거웠다고 감사 인사를 한다",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_0401_1200_10": "그렇게 즐길 수 있는 것도\n진지하게 마주하고 있기 때문이겠지!",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_0401_1300_10": "역시 네게 부탁하길 잘한 것 같아!",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_0302_1400_10": "답은 찾았는지 물어본다",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_0402_1500_10": "응!",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_0402_1600_10": "내 나름대로 답을 찾았어!\n네가 도와준 덕분이야!",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_1700_10": "[Name:PlayerNickname ][Kor:Particle char=\"ha\" ]\n정말로 믿음직스러운 파트너였어",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_1800_10": "하지만 다음번에는 서로 경쟁하는\n라이벌로서 이기고 싶어!",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_1900_10": "상행도 분명\n같은 생각일 거야",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_2000_10": "상행도 언젠가는 네가 고른\n최고의 태그 파트너와\n전력을 다한 진지한 대결을 하고 싶을걸!",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_2100_10": "나도 상행과 함께\n너와 진심을 맞부딪치고 싶어!",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_2200_10": "네가 결성한 태그는\n확실히 엄청 강하겠지만...",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_2300_10": "우리 서브웨이마스터도\n절대 지지 않을 거야!"
}
