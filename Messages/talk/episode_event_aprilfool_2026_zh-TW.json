{
    "episode_event_aprilfool_2026/6901_1001_0100_10": "麻吉麻吉～！！",
    "episode_event_aprilfool_2026/6901_1001_0200_10": "咦，這個聲音是……！？",
    "episode_event_aprilfool_2026/6901_1001_0300_10": "麻吉麻吉～！！",
    "episode_event_aprilfool_2026/6901_1001_0400_10": "麻吉麻吉～！！",
    "episode_event_aprilfool_2026/6901_1001_0500_10": "呃……！？",
    "episode_event_aprilfool_2026/6901_1001_0600_10": "不會吧，這個舞該不會\n又是桃歹郎牠……！？",
    "episode_event_aprilfool_2026/6901_1001_0700_10": "哈哈哈！\n哎呀，真是抱歉！",
    "episode_event_aprilfool_2026/6901_1001_0800_10": "我們跳的這個舞\n跟桃歹郎沒有關係！",
    "episode_event_aprilfool_2026/6901_1001_0900_10": "咦……？",
    "episode_event_aprilfool_2026/6901_1001_1000_10": "其實是我們發現這個舞\n對肌力訓練很有幫助！",
    "episode_event_aprilfool_2026/6901_1001_1100_10": "跳這個舞還挺開心的，\n大家也會露出笑容……",
    "episode_event_aprilfool_2026/6901_1001_1200_10": "而且我們現在在社群平台上\n也變得小有名氣了！",
    "episode_event_aprilfool_2026/6901_1001_1300_10": "啥～！？什麼跟什麼啊！\n不要做這種引人誤會的事啦！",
    "episode_event_aprilfool_2026/6901_1001_1400_10": "……算了，只要你們不是\n被桃歹郎操控就好。",
    "episode_event_aprilfool_2026/6901_1001_1500_10": "即使如此！\n我也已經受夠這個舞了！",
    "episode_event_aprilfool_2026/6801_1031_0100_10": "真是的……！",
    "episode_event_aprilfool_2026/6801_1001_0100_10": "簡直煩死人了！",
    "episode_event_aprilfool_2026/6801_1001_0200_10": "那個舞到底有哪一點\n會讓人上癮啊……！"
}
