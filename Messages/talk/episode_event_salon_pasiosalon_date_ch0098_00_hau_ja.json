{
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4001_1101_0100_20": "パシオアカデミーで\n好成績を　収めた　[Name:PlayerNickname ]",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4001_1101_0200_20": "すると……",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4001_1001_0300_10": "[Name:PlayerNickname ]　きいたよー！\nおめでとー！",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4001_1001_0400_10": "いい成績　取れたんでしょー？\nおれも　勉強　がんばらないとだなー",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4001_1001_0500_10": "そうだ　せっかくだし\nお祝いしようよー！\n時間　あるときで　いいからさー",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4001_1001_0600_10": "わーい！　やったー！\n楽しみー！",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4001_1001_0700_10": "アローラでもねー\nおめでたいことが　あったら\nお祭りをして　楽しんだんだー",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4001_1001_0800_10": "おれは　毎日が　お祭りでも\nいいと　思うんだけど\n大人って　かっこつけ　だからなー",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4001_1001_0900_10": "楽しむための　理由が\nほしいのかもねー",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4001_1001_1000_10": "あっ　でも……",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4001_1001_1100_10": "お祭りとかお祝いの　準備をしてるときの\nワクワクは　味わいたいかもー！",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4001_1001_1200_10": "よーし　今回も　おいしいものを\nたくさん用意してー　あとはー……",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4001_1001_1300_10": "なにか　[Name:PlayerNickname ]に\nプレゼントしたいなー！",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4001_1001_1400_10": "ねーねー\nなにか　ほしい物　ある？",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4001_1001_1500_10": "とくに　ないのー？\n遠慮しなくて　いいのにー",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4001_1001_1600_10": "じゃあ　なにか食べながら　悩みごとを\nききあう会に　しよっかー！",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4001_1001_1700_10": "明るく　みえる人でも　じつは\n悩みを　抱えてること　あるからさー",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1101_0100_20": "後日……",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_0200_10": "マラサダと　パンケーキ\nたくさん　用意したからさー\n食べながら　ゆっくり　話そうー！",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_0300_10": "……うんうん　そっかー",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_0400_10": "みんなに　どうやって\n恩返ししたら　いいか\nわからないんだねー？",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_0500_10": "やっぱり　[Name:PlayerNickname ]にも\n悩みって　あるんだー",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_0600_10": "でもー　おれも　みんなも\nきみに　たくさん　支えられてるよー？",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_0700_10": "だから　恩返しなんて　難しいこと\n考えなくたって　大丈夫だよー！",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_0800_10": "……おれも　アローラで\n悩んでるときが　あったんだー",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_0900_10": "しまキングの　じーちゃんと\n比べられることが　多かったからさー",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_1000_10": "だから　ポケモン勝負は\n勝つことは　あんまり　考えないで\n楽しむことを　大事にしてた",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_1100_10": "だけど　あるとき\n本気で　勝ちたいって\n思ったときが　あってね……",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_1200_10": "ゼンリョクで　ぶつかったんだけど\n負けて　めちゃくちゃ　悔しかったなー！",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_1300_10": "その悔しさを　どう受け止めたら\nいいか　わかんなくてー……\nすっごく　悩んじゃったんだよねー",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_1400_10": "でも　ともだちと　冒険して\nいろんなことを　乗りこえてるうちに\n悩みは　全部　吹き飛んじゃったー！",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_1500_10": "ひとりだと　どうすればいいか\nわからないことも……",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_1600_10": "みんなと　一緒なら\nきっと　大丈夫　なんだよー",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_1700_10": "だから　[Name:PlayerNickname ]も\n今のままで　いいと　思うなー！",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_1800_10": "……あ　おれが　悩んでた\nって　ことは　内緒だよー？",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_0301_1900_10": "打ち明けてくれた　お礼をいう",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_0401_2000_10": "えへへー\nふたりだけの　秘密だねー！",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_0302_2100_10": "悩んでたことを　意外だという",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_0402_2200_10": "あははー！\nそれは　[Name:PlayerNickname ]もねー！",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_2300_10": "今日みたいに　おいしいものは\nみんなで　食べれば\nもっと　おいしくなるし……",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_2400_10": "悩みごとは　みんなと\n笑いあったら　小さくなるんだよー",
    "episode_event_salon_pasiosalon_date_ch0098_00_hau/4002_1001_2500_10": "これからも　きっと　ふたりでなら\nなんとか　なるよねー！"
}
