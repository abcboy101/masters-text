{
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_1101_0100_20": "某天，[Name:PlayerNickname ]因為\n北尚有事相求而被叫了出來……",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_1001_0200_10": "今日忽然找您出來，\n實在萬分抱歉！",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_1001_0300_10": "那我就開門見山地問了，\n請問您能不能暫時……",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_1001_0400_10": "當我的組隊對戰隊友，\n與我並肩作戰呢？",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_0301_0500_10": "南廈呢？",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_0401_0600_10": "您不必擔心！\n因為這麼做也是為了南廈好！",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_0302_0700_10": "為什麼會找我？",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_0402_0800_10": "您似乎很納悶我為何不找南廈……\n但這是有理由的！",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_1001_0900_10": "我想要款待每一位挑戰者，\n讓他們達到更高的境界……",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_1001_1000_10": "可是在高手雲集的帕希歐，\n我越來越常感受到自己與南廈組成的\n兩輛車廂編組實力還是不太夠。",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_1001_1100_10": "所以我就想說要和您一起\n組隊對戰並從中找到新發現，\n讓自己達到更高的境界！",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_1001_1200_10": "這麼做也是為了\n平時與我一起組隊對戰的南廈！",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_1001_1300_10": "我和南廈是雙胞胎，\n兩人總是互相扶持。",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_1001_1400_10": "即使有一方試圖走在前頭，\n兩人也會在不知不覺間並肩而行……",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_1001_1500_10": "我們就是這樣\n一路成長過來的！",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_1001_1600_10": "所以只要和您一起\n爬上更高的境界……",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_1001_1700_10": "南廈之後肯定也會追上來！",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_1001_1800_10": "最後我們兄弟倆\n都能達到更高的境界！",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_1001_1900_10": "我是抱著這樣的想法來拜託您的，\n不知您意下如何？",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_1001_2000_10": "棒極了！！\n感謝您爽快地答應！",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4001_1001_2100_10": "這段時間就以[Name:PlayerNickname ]您\n和我的兩輛車廂編組，\n朝著目的地前進吧！",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4002_1101_0100_20": "幾天後……",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4002_1001_0200_10": "您以隊友的身分\n與我並肩作戰到今天……",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4002_1001_0300_10": "我由衷地向您致上謝意！",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4002_1001_0400_10": "……南廈肯定也會大吃一驚吧。",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4002_1001_0500_10": "仔細一想，我在帕希歐\n體驗了許多從未經歷過的事。",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4002_1001_0600_10": "像這次這樣，\n與南廈分開行動的機會\n也出現過不少次呢！",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4002_1001_0700_10": "若是「跟平時一樣」的話，\n即使兄弟組隊有缺點，\n有時也不會注意到。",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4002_1001_0800_10": "但像這樣分開之後，\n就能夠注意到平時因為\n過於理所當然而沒能發現的事情。",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4002_1001_0900_10": "這次我也透過\n與您一起組隊對戰……",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4002_1001_1000_10": "發現了原以為與南廈組隊時\n「完美無缺！」的部分\n也還有改善的空間！",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4002_1001_1100_10": "我再次體悟到偶爾像這樣\n分開來重新審視彼此的時間\n果然是有必要的！",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4002_0301_1200_10": "很高興能幫上忙",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4002_0401_1300_10": "您太客氣了！\n您的協助簡直可靠至極！",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4002_0302_1400_10": "南廈也會這樣覺得嗎？",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4002_0402_1500_10": "那是當然的！\n無論我們離得多遠，\n心都會與彼此同在！",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4002_1001_1600_10": "雖然我們在帕希歐\n也遇見了許多人……",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4002_1001_1700_10": "但能夠與我們組隊的\n訓練家並不多。",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4002_1001_1800_10": "[Name:PlayerNickname ]您是非常了解\n地下鐵總管的人！",
    "episode_event_salon_pasiosalon_date_ch0108_00_nobori/4002_1001_1900_10": "今後還請您與我們兄弟倆\n長久保持良好的關係了！"
}
