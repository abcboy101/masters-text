{
    "episode_event_academy_spring_2026/4001_1101_0100_20": "파시오 아카데미에서\n학교 축제의 개최가 결정되었다",
    "episode_event_academy_spring_2026/4001_1101_0200_20": "개최는 아직 멀었지만\n학생들은 지금부터 다양한\n콘텐츠를 기획하고 있다...",
    "episode_event_academy_spring_2026/4001_1001_0300_10": "모두 열심히 하고 있네...",
    "episode_event_academy_spring_2026/4001_1001_0400_10": "나도 학교 축제에\n참가할 생각이지만",
    "episode_event_academy_spring_2026/4001_1001_0500_10": "누구와 어떤 콘텐츠를 해야 할지\n아직 전혀 떠오르지 않아...",
    "episode_event_academy_spring_2026/4001_1001_0600_10": "애초에 나는 얼마 전까지\n팔데아지방의 아카데미에도\n잘 안 나갔으니까...",
    "episode_event_academy_spring_2026/4001_1001_0700_10": "학교 축제를\n어떻게 즐겨야 할지\n아직 잘 모르겠어...",
    "episode_event_academy_spring_2026/4001_1001_0800_10": "친한 친구들과 함께하는 게\n가장 좋다곤 생각하지만...",
    "episode_event_academy_spring_2026/4001_1001_0900_10": "고민이 있나 보구나, 소년!",
    "episode_event_academy_spring_2026/4001_1001_1000_10": "시간은 소중하지!\n고민하기엔 시간이 아깝다구!",
    "episode_event_academy_spring_2026/6801_1031_0100_10": "선생님이면서\n동시에 학생이라...",
    "episode_event_academy_spring_2026/6801_1001_0100_10": "평소엔 선생님인 사람과\n학생으로서 같이 공부를 하는 건\n이상한 느낌이네...",
    "episode_event_academy_spring_2026/6801_1001_0200_10": "날 그렇게 너무 어렵게\n생각할 필요 없어!",
    "episode_event_academy_spring_2026/6801_1001_0300_10": "나도 마찬가지야!\n렌즈를 향해 자연스럽게\n미소를 지어 줘~!",
    "episode_event_academy_spring_2026/4002_1001_0100_10": "당신은 분명 사진가...",
    "episode_event_academy_spring_2026/4002_1001_0200_10": "맞아! 세류 누나야!\n푸름한테 들었어?",
    "episode_event_academy_spring_2026/4002_1001_0300_10": "[Name:PlayerNickname ]도 안녕!",
    "episode_event_academy_spring_2026/4002_1001_0400_10": "뭐야?\n[Name:PlayerNickname ], 아는 사이였어?",
    "episode_event_academy_spring_2026/4002_1001_0500_10": "이쪽은 소니아!\n가라르지방의 포켓몬 박사님이야!",
    "episode_event_academy_spring_2026/4002_1001_0600_10": "오...! 가라르지방의...!",
    "episode_event_academy_spring_2026/4002_1001_0700_10": "잘 부탁해!\n그러니까 너는...",
    "episode_event_academy_spring_2026/4002_1001_0800_10": "저는 페퍼!\n[Name:PlayerNickname ]의 친구죠!",
    "episode_event_academy_spring_2026/4002_1001_0900_10": "저야말로 잘 부탁드릴게요!",
    "episode_event_academy_spring_2026/4002_1001_1000_10": "그런데 두 분의 그 모습은...",
    "episode_event_academy_spring_2026/4002_1001_1100_10": "그렇구나, [Name:PlayerNickname ]하고도\n학생으로 만나는 건 처음이었나?",
    "episode_event_academy_spring_2026/4002_1001_1200_10": "포켓몬 박사님에 사진가라고 해서\n선생님으로 온 건 줄 알았어요",
    "episode_event_academy_spring_2026/4002_1001_1300_10": "물론 평소에는 선생님으로서\n교단에 서는 일도 많지!",
    "episode_event_academy_spring_2026/4002_1001_1400_10": "하지만 지금은 모두하고 똑같이...\n학생으로서 학교생활을 즐기고 있어!",
    "episode_event_academy_spring_2026/4002_1001_1500_10": "그리고 이 모습으로 있으면\n아카데미의 취재 활동도\n한층 더 의욕이 생긴단 말이지~!",
    "episode_event_academy_spring_2026/4002_1001_1600_10": "...취재요?",
    "episode_event_academy_spring_2026/4002_1001_1700_10": "그래!",
    "episode_event_academy_spring_2026/4002_1001_1800_10": "지금은 파시오 아카데미의\n홍보 기사를 위해서 학교 축제를\n취재하고 있거든!",
    "episode_event_academy_spring_2026/4002_1001_1900_10": "준비 단계부터 의욕이 넘치는\n학생들의 모습을 사진에 담아서...",
    "episode_event_academy_spring_2026/4002_1001_2000_10": "개최까지 특집으로\n기사를 내는 거야~!",
    "episode_event_academy_spring_2026/4002_1001_2100_10": "오... 학교 축제의 뒤에선\n그런 활동도 진행되고 있었군요",
    "episode_event_academy_spring_2026/4002_1001_2200_10": "외부의 \"카메라맨\"과\n아카데미의 \"학생\"은\n찍는 사진의 분위기가 다르니까",
    "episode_event_academy_spring_2026/4002_1001_2300_10": "같은 학생의 눈높이에서\n찍는 사진이 신선하고 재밌다구!",
    "episode_event_academy_spring_2026/4002_1001_2400_10": "나도 그런 세류의\n시점이 좋다고 생각해서",
    "episode_event_academy_spring_2026/4002_1001_2500_10": "취재를 할 때는 이렇게\n학생으로 활동하고 있어!",
    "episode_event_academy_spring_2026/4002_1001_2600_10": "맞아, 괜찮다면 너희들도\n학교 축제를 같이 취재하러 가지 않을래?",
    "episode_event_academy_spring_2026/4002_1001_2700_10": "네? 그래도 되나요?",
    "episode_event_academy_spring_2026/4002_1001_2800_10": "응, 콘텐츠를 못 정해서\n고민하고 있는 것 같으니까...",
    "episode_event_academy_spring_2026/4002_1001_2900_10": "다른 사람들이\n어떤 콘텐츠를 하는지 알게 되면\n참고가 되지 않을까?",
    "episode_event_academy_spring_2026/4002_1001_3000_10": "그거 일리가 있네요...!",
    "episode_event_academy_spring_2026/4002_1001_3100_10": "그럼 결정!\n바로 출발할까?",
    "episode_event_academy_spring_2026/4002_1001_3200_10": "그러고 보니 아카데미 밖에서 준비하는\n그룹도 있다고 들었어요",
    "episode_event_academy_spring_2026/4002_1001_3300_10": "취재 대상이 파시오 전체에\n퍼져 있다면 다 보는 건\n어렵지 않을까요...?",
    "episode_event_academy_spring_2026/4002_1001_3400_10": "괜찮아! 그건 맡겨만 줘!",
    "episode_event_academy_spring_2026/4002_1001_3500_10": "이 두 마리의 힘을 빌리면\n어디든지 단숨에 갈 수 있다구!",
    "episode_event_academy_spring_2026/4002_1001_3600_10": "오오! 이건 든든하네요!",
    "episode_event_academy_spring_2026/4002_1001_3700_10": "그럼 다시 한번!\n학교 축제를 취재하러 출발~!",
    "episode_event_academy_spring_2026/4003_1001_0100_10": "이 그룹의 기획은\n\"유령의 집\"이구나...!",
    "episode_event_academy_spring_2026/4003_1001_0200_10": "있지, 이 기획만의 특색이 있을까?",
    "episode_event_academy_spring_2026/4003_1001_0300_10": "아, 네...!",
    "episode_event_academy_spring_2026/4003_1001_0400_10": "그러니까...\n중요하게 생각한 건 의상과 연출이고...",
    "episode_event_academy_spring_2026/4003_1001_0500_10": "모두가 고스트포켓몬의\n좋은 점을 맛보게 하고 싶어!",
    "episode_event_academy_spring_2026/4003_1001_0600_10": "확실히 의상이 모두 매력적이네!",
    "episode_event_academy_spring_2026/4003_1001_0700_10": "그리고 가장 큰 매력은\n본격적인 공포 체험이지",
    "episode_event_academy_spring_2026/4003_1001_0800_10": "우리 유령의 집은\n가짜가 아니라...",
    "episode_event_academy_spring_2026/4003_1001_0900_10": "진짜를 체험할 수 있으니까",
    "episode_event_academy_spring_2026/4003_1001_1000_10": "앗! 다들 다녀와!",
    "episode_event_academy_spring_2026/4003_1001_1100_10": "너무 본격적이라서...\n손님이 기절하지 않을까 걱정되네",
    "episode_event_academy_spring_2026/4004_1001_0100_10": "우리 \"밴드\"는\n프로든 아마추어든 다 상관없어!",
    "episode_event_academy_spring_2026/4004_1001_0200_10": "하나 더 말하자면 노래하고 싶거나\n연주하고 싶고 춤추고 싶은...\n음악에 관련된 거라면 뭐든지 대환영이야!",
    "episode_event_academy_spring_2026/4004_1001_0300_10": "연주나 댄스를 보여 줄\n이벤트 스테이지를 기획하고 있어!",
    "episode_event_academy_spring_2026/4004_1001_0400_10": "오~!\n다루는 게 많은 그룹이구나!",
    "episode_event_academy_spring_2026/4004_1001_0500_10": "당일 참가도 가능하니까\n계속해서 동료를 모집 중이야!",
    "episode_event_academy_spring_2026/4004_1001_0600_10": "정말 좋은데~!\n좀 더 다양한 포즈 부탁할게!",
    "episode_event_academy_spring_2026/4004_1001_0700_10": "좋았어!\n이런 동작은 어떨까?",
    "episode_event_academy_spring_2026/4004_1001_0800_10": "같은 취미를 가진\n친구와 즐길 수 있는...\n그런 콘텐츠도 괜찮겠어!",
    "episode_event_academy_spring_2026/4005_1001_0100_10": "\"찻집\"에서는\n수제 과자와 음료를\n제공할 예정이에요!",
    "episode_event_academy_spring_2026/4005_1001_0200_10": "방문한 손님을\n기합으로 대접합니다!",
    "episode_event_academy_spring_2026/4005_1001_0300_10": "코크런씨도\n접객을 하시나요?",
    "episode_event_academy_spring_2026/4005_1001_0400_10": "아뇨, 저는 감수하는 역할을\n맡기로 했습니다",
    "episode_event_academy_spring_2026/4005_1001_0500_10": "코크런님에게 접객과\n요리에 도움을 받아서...",
    "episode_event_academy_spring_2026/4005_1001_0600_10": "현역 집사가 감수한\n본격적인 카페라고 어필할 생각이에요!",
    "episode_event_academy_spring_2026/4005_1001_0700_10": "요리라...",
    "episode_event_academy_spring_2026/4005_1001_0800_10": "요리라면 나도...\n학교 축제에서 모두를 즐겁게\n만들 수 있을지도 몰라",
    "episode_event_academy_spring_2026/4005_1001_0900_10": "저기! 괜찮다면\n나도 찻집에 참가하게 해 줘!",
    "episode_event_academy_spring_2026/4005_1001_1000_10": "물론 환영이야!\n너의 요리에 대한 이야기는 이미 들었어!",
    "episode_event_academy_spring_2026/4005_1001_1100_10": "응!\n참가해 준다면 굉장히 든든할 거야!",
    "episode_event_academy_spring_2026/4005_1001_1200_10": "믿음직스러운 동료를\n데려와 주셔서 감사합니다!",
    "episode_event_academy_spring_2026/4005_1001_1300_10": "후후!\n우리가 꽤 도움이 됐나 본데?",
    "episode_event_academy_spring_2026/4005_1001_1400_10": "그러게! 모두 좋은 표정이야!\n나이스한 특집이 될 것 같아~!",
    "episode_event_academy_spring_2026/4006_1001_0100_10": "아머까오!\n하루 종일 데리고 다녀 줘서 고마워!",
    "episode_event_academy_spring_2026/4006_1001_0200_10": "야부엉도!\n덕분에 학교 축제의 콘텐츠를\n빠짐없이 취재할 수 있었어!",
    "episode_event_academy_spring_2026/4006_1001_0300_10": "이제 푹 쉬어!",
    "episode_event_academy_spring_2026/4006_1001_0400_10": "나도 감사 인사를 할게!\n너희들, 정말 고맙다!",
    "episode_event_academy_spring_2026/4006_1001_0500_10": "그리고 세류님과\n소니아님도요!",
    "episode_event_academy_spring_2026/4006_1001_0600_10": "두 분 덕분에\n하고 싶은 걸 찾았어요!",
    "episode_event_academy_spring_2026/4006_1001_0700_10": "[Name:PlayerNickname ]도\n함께해 줘서 고마워!",
    "episode_event_academy_spring_2026/4006_1001_0800_10": "도움이 돼서 다행이야!",
    "episode_event_academy_spring_2026/4006_1001_0900_10": "좋~아!\n나도 학교 축제를 즐겁게 만들겠어!!",
    "episode_event_academy_spring_2026/4006_1001_1000_10": "응응, 바로 그거야!\n학교 축제라고 하면\n일단 학생이 즐거워해야지!",
    "episode_event_academy_spring_2026/4006_1001_1100_10": "어라...? 그러고 보니\n두 분도 학생이신 거잖아요?",
    "episode_event_academy_spring_2026/4006_1001_1200_10": "홍보하는 일 말고 학교 축제에서\n따로 하고 싶으신 건 없어요?",
    "episode_event_academy_spring_2026/4006_1001_1300_10": "듣고 보니 그렇네...\n취재에 정신이 팔려서 생각을 못 했어",
    "episode_event_academy_spring_2026/4006_1001_1400_10": "확실히 모처럼 학생으로\n학교 축제에 참가하는 거니까...\n우리들도 뭔가 해 보고 싶긴 해",
    "episode_event_academy_spring_2026/4006_1001_1500_10": "그럼 나는...\n\"사진전\"을 열어 보고 싶은걸?",
    "episode_event_academy_spring_2026/4006_1001_1600_10": "나는 \"포켓몬 연구 발표회\"를\n해 보고 싶어!",
    "episode_event_academy_spring_2026/4006_1001_1700_10": "어쩐지 두 분답네요!\n어떤 콘텐츠가 될지\n기대하고 있을게요!",
    "episode_event_academy_spring_2026/4006_1001_1800_10": "헤헤헤!\n같은 걸 몰두할 수 있는\n친구와의 시간은...",
    "episode_event_academy_spring_2026/4006_1001_1900_10": "학교생활의 잊지 못할\n추억이 될 거야!"
}
