{
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1101_0100_20": "어느 날 [Name:PlayerNickname ][Kor:Particle char=\"ha\" ]\n윤슬에게 불려 나왔다",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_0200_10": "[Name:PlayerNickname ], 와 줘서 고마워",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_0300_10": "할 이야기란 건 말이지...",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_0400_10": "늘 잘해 주는 너에게\n보답을 하고 싶었어",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_0500_10": "파시오에 온 지 얼마 안 됐을 때는\n모르는 게 많아서 불안했지만...",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_0600_10": "[Name:PlayerNickname ][Kor:Particle char=\"ga\" ] 그런 나를 보고\n늘 신경 써 줬어서\n그 상냥한 마음이 든든했거든",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_0700_10": "그러니까 너한테\n어떻게든 보답을 하고 싶다는 이야기야!",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_0800_10": "이런 건 어떨까?\n내가 잘하는 공작을 가르쳐 줄 테니\n뭔가 만들어 볼래?",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_0900_10": "이 시대에는 좋은 물건들을\n뭐든 쉽게 구할 수 있지만",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_1000_10": "그래서 수제만의 장점이\n더 돋보인다고도 생각하거든!",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_1100_10": "다만...\n수고스러운 건 사실이고",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_1200_10": "가게에서 사는 것보다\n좋은 품질로 만드는 건 어려워서\n필요하지는 않을 수도 있겠지만...",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_0301_1300_10": "그렇지 않다고 말한다",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_0401_1400_10": "그래...?",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_0401_1500_10": "도움이 된다니 기뻐!",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_0302_1600_10": "직접 만드는 걸 좋아한다고 말한다",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_0402_1700_10": "정말? 기쁘다!",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_1800_10": "그러면 공작의 명인으로서\n직접 만드는 요령을 가르쳐 줄게",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_1900_10": "작업이 일단락되고 나서\n토란떡도 먹을 수 있으면 좋을 것 같네...",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_2000_10": "히스이지방의 토란떡은\n연기토란으로 만드는 음식인데",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_2100_10": "축복마을에서는 임무가 끝나면\n자주 먹곤 했어",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_2200_10": "히스이지방에서는 익숙한\n그 맛을 파시오에서도 재현해 보려고 해",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4001_1001_2300_10": "너한테도 맛보여 주고 싶으니까\n다음에 힘내서 만들어 볼게!",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1101_0100_20": "며칠 후...",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_0200_10": "[Name:PlayerNickname ]!\n공작은 잘되고 있어?",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_0300_10": "익숙해질 때까지\n시간이 필요하겠지만",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_0400_10": "경험이 중요하니까\n열심히 해 봐!",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_0500_10": "그리고 사실은\n나도 오늘 토란떡을 만들었어!",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_0600_10": "전에 이야기했던 거 기억하지?",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_0700_10": "히스이지방의 맛을 재현하려고\n바로 도전해 봤거든",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_0800_10": "하지만 아쉽게도\n히스이지방에 있었던\n연기토란은 구할 수가 없어서",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_0900_10": "다른 재료로 대체해서\n간신히 그럴듯한 걸 만들긴 했지만\n솔직히 별로 자신은 없더라고...",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_1000_10": "...여, 역시 오늘은 안 줄래!",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_1100_10": "다음번에 잘 만들어지면\n그때 가져올게!",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_0301_1200_10": "꼭 먹어보고 싶다고 말한다",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_0401_1300_10": "그, 그렇게 말해 준다면야...",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_0302_1400_10": "자신감을 가지라고 말한다",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_0402_1500_10": "...그렇겠지?\n내가 만든 건데 이러면 안 되겠지!",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_0402_1600_10": "알았어\n모처럼 만든 거니 먹어 줘!",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_1700_10": "아, 하지만 조금 쑥스러우니까\n이따가 먹으면 안 될까?",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_1800_10": "감상은 다음에 만났을 때\n듣는 거로 하고...!",
    "episode_event_salon_pasiosalon_date_ch0291_00_sho/4002_1001_1900_10": "그러면 다음에는\n더 맛있게 만들 수 있도록 힘내 볼게!"
}
