{
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1101_0100_20": "ある日　[Name:PlayerNickname ]は\nクダリから　頼みがあると\n呼びだされた……",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_0200_10": "お願い　[Name:PlayerNickname ]\nぼくと　タッグを　組んで！",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_0300_10": "え？　どうして　こんなこと\nお願いするのか　気になる？",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_0400_10": "ぼく　この島の\nバディーズをみて　考えてた",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_0500_10": "なにが　真剣勝負なのか\n人によって　全然　違うんだ　って",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_0600_10": "すごく　勝ちたい　気持ち　\n本物の　気持ちを　ぶつけあう\nそれが　ぼくの　真剣勝負",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_0700_10": "だけど　特定のタイプや　戦法で\n戦うことが　真剣勝負　だって\nいう人も　いるし",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_0800_10": "勝ち負けに　こだわらず\nショーみたいな　ポケモン勝負で\nお客さんを　魅了したい　人もいる",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_0900_10": "だから　ぼく\nみんなの　真剣勝負って　なにか\nもっと　知りたい！",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_1000_10": "いろんな　真剣勝負の　形を　知れば\nきっと　今より　楽しくなるはず",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_1100_10": "そのとき　思い浮かんだんだ\n[Name:PlayerNickname ]の　顔が！",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_1200_10": "きみは　いつも　全力\nなんにでも　真剣",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_1300_10": "きみと　タッグを　組めば\n絶対　勉強になる！",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_1400_10": "きみとなら　きっと\n新しい発見が　できる！",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_0301_1500_10": "ノボリでなくて　よいのか　きく",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_0401_1600_10": "うん　今回は\nきみとが　いい！",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_0302_1700_10": "ノボリにも伝えてあるのか　きく",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_0402_1800_10": "ノボリには　なにも　いってない\nけど　大丈夫",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_1900_10": "ノボリも　きっと\nぼくと　同じこと　考えてる",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_2000_10": "サブウェイマスターとして　より\n高みを　目指して　動いてるはず",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_2100_10": "離れてても　ぼくたちの\nコンビネーションは　バツグン！",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4001_1001_2200_10": "進む　線路は　違っても……\n終着駅は　きっと　同じ！",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1101_0100_20": "後日……",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_0200_10": "ありがとう　[Name:PlayerNickname ]\nぼくの　お願い　きいてくれて",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_0300_10": "きみとの　タッグバトル\nどれも　すごく　楽しかった！",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_0400_10": "それに　わかったこともある",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_0500_10": "きみは　なんにでも\n真剣　なんじゃない",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_0600_10": "なにかと　向きあうことに\n全部　真剣なんだ",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_0700_10": "ポケモンにも　勝負にも\nそれに　人の　想いにも！",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_0800_10": "相手を　理解したり\n近づきたいって　気持ちが　強いんだ",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_0900_10": "だから　ぼくにも\n真剣に　向きあって　くれた",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_1000_10": "きみと　一緒だと\nすごく　戦いやすかったし\nなにより　楽しかった！",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_0301_1100_10": "自分も楽しかった　と感謝する",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_0401_1200_10": "そうやって　楽しめるのも\n真剣に　向きあってるから　なんだね！",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_0401_1300_10": "やっぱり　きみに\n頼んで　よかった！",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_0302_1400_10": "答えが　みつかったか　きく",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_0402_1500_10": "うん！",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_0402_1600_10": "ぼくなりの　答え　みつかった！\nきみが　協力してくれた　おかげ！",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_1700_10": "[Name:PlayerNickname ]は\nすごく　心強い　パートナーだった",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_1800_10": "でも　次は　競いあう\nライバルとして　勝ちたい！",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_1900_10": "ノボリも　きっと\n同じこと　思うはず",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_2000_10": "いつか　きみが　選んだ\n最高の　タッグパートナーと\n真剣勝負　したいって！",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_2100_10": "ノボリと　一緒に　きみと\n本物の　気持ち　ぶつけあいたい！",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_2200_10": "きっと　きみが　結成した\nタッグは　すっごく　強い\nだけど……",
    "episode_event_salon_pasiosalon_date_ch0109_00_kudari/4002_1001_2300_10": "ぼくたち　サブウェイマスターも\n絶対　負けない！"
}
